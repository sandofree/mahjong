<!-- pages/camera/camera.wxml -->
<view class="camera-container">
  <!-- 拍照模式 -->
  <view class="camera-view" wx:if="{{!hasPhoto}}">
    <camera
      device-position="back"
      flash="off"
      binderror="onCameraError"
      class="full-camera"
    >
      <!-- 取景框引导：半透明遮罩 + 正方形镂空（适配640x640模型输入） -->
      <view class="guide-overlay">
        <view class="guide-mask guide-mask-top"></view>
        <view class="guide-row">
          <view class="guide-mask guide-mask-side"></view>
          <view class="guide-window">
            <view class="guide-corners">
              <view class="corner corner-tl"></view>
              <view class="corner corner-tr"></view>
              <view class="corner corner-bl"></view>
              <view class="corner corner-br"></view>
            </view>
          </view>
          <view class="guide-mask guide-mask-side"></view>
        </view>
        <view class="guide-mask guide-mask-bottom"></view>
        <view class="guide-hint">请将14张手牌放入框内</view>
      </view>
    </camera>

    <!-- 拍照按钮 -->
    <view class="capture-bar">
      <view class="capture-btn" bindtap="onTakePhoto">
        <view class="capture-inner"></view>
      </view>
    </view>
  </view>

  <!-- 预览模式 -->
  <view class="preview-view" wx:if="{{hasPhoto}}">
    <image class="preview-image" src="{{photoPath}}" mode="aspectFit"></image>

    <view class="preview-actions">
      <button class="btn-retake" bindtap="onRetake">重新拍照</button>
      <button class="btn-confirm" bindtap="onConfirm">确认识别</button>
    </view>
  </view>
</view>

<!-- 识别中提示 -->
<view class="loading-mask" wx:if="{{recognizing}}">
  <view class="loading-spinner"></view>
  <view class="loading-text">云端图像识别中...</view>
  <view class="loading-sub">正在分析牌面，请稍候 {{recognizingSeconds}} 秒</view>
  <view class="loading-tip">AI 视觉识别约需 10-20 秒</view>
</view>
