/* pages/camera/camera.wxss */

.camera-container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #000;
}

.camera-view {
  width: 100%;
  height: 100%;
  position: relative;
}

.full-camera {
  width: 100%;
  height: 100%;
}

/* 取景框引导 — 半透明遮罩 + 正方形镂空窗口（适配 640x640 模型输入） */
.guide-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}

.guide-mask {
  background: rgba(0, 0, 0, 0.45);
}

.guide-mask-top,
.guide-mask-bottom {
  width: 100%;
  flex: 1;
}

.guide-row {
  width: 100%;
  display: flex;
  flex-direction: row;
}

.guide-mask-side {
  flex: 1;
}

.guide-window {
  width: 560rpx;
  height: 560rpx;
  position: relative;
}

/* 四角标记 */
.guide-corners {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: rgba(255, 255, 255, 0.85);
  border-style: solid;
}

.corner-tl { top: 0; left: 0; border-width: 6rpx 0 0 6rpx; border-radius: 8rpx 0 0 0; }
.corner-tr { top: 0; right: 0; border-width: 6rpx 6rpx 0 0; border-radius: 0 8rpx 0 0; }
.corner-bl { bottom: 0; left: 0; border-width: 0 0 6rpx 6rpx; border-radius: 0 0 0 8rpx; }
.corner-br { bottom: 0; right: 0; border-width: 0 6rpx 6rpx 0; border-radius: 0 0 8rpx 0; }

/* 框内提示文字 */
.guide-hint {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  width: 100%;
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.45);
  padding: 10rpx 0;
}

/* 拍照按钮 */
.capture-bar {
  position: absolute;
  bottom: 80rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
}

.capture-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 8rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.capture-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #fff;
}

/* 预览视图 */
.preview-view {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #000;
}

.preview-image {
  flex: 1;
  width: 100%;
}

.preview-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: #000;
}

.btn-retake {
  width: 240rpx;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #555;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-confirm {
  width: 240rpx;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2d5016, #4a7c23);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

/* loading spinner */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-sub {
  color: #fff;
  font-size: 26rpx;
  margin-top: 12rpx;
  opacity: 0.85;
}

.loading-tip {
  color: rgba(255,255,255,0.6);
  font-size: 22rpx;
  margin-top: 8rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
