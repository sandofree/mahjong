/* pages/camera/camera.wxss */

.camera-container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #000;
}

.camera-view {
  width: 100%;
  height: 100%;
  position: relative;
}

.full-camera {
  width: 100%;
  height: 100%;
}

/* 取景框引导 */
.guide-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.guide-frame {
  width: 620rpx;
  height: 420rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
}

/* 拍照按钮 */
.capture-bar {
  position: absolute;
  bottom: 80rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
}

.capture-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 8rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.capture-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #fff;
}

/* 预览视图 */
.preview-view {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #000;
}

.preview-image {
  flex: 1;
  width: 100%;
}

.preview-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: #000;
}

.btn-retake {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #555;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-confirm {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #2d5016, #4a7c23);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
}

/* loading spinner */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
