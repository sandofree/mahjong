/* pages/input/input.wxss */

/* 已选区域 */
.selected-area {
  width: 100%;
  margin-bottom: 24rpx;
}

.selected-title {
  font-size: 28rpx;
  color: #2d5016;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-align: center;
}

.tile-empty {
  width: 68rpx;
  height: 92rpx;
  border: 3rpx dashed #ccc;
  border-radius: 10rpx;
  background: rgba(255,255,255,0.5);
}

/* 上下文区域 */
.context-area {
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.context-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.context-label {
  font-size: 24rpx;
  color: #666;
}

.context-check {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #2d5016;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #2d5016;
}

.context-check.checked {
  background: #2d5016;
  color: #fff;
}

.context-picker {
  font-size: 28rpx;
  color: #2d5016;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  background: #fafafa;
}

/* 牌面选择网格 */
.tiles-grid {
  width: 100%;
  margin-bottom: 24rpx;
}

.suit-group {
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.suit-label {
  font-size: 26rpx;
  color: #2d5016;
  font-weight: bold;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #2d5016;
}

.suit-tiles {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tile-selector {
  width: 96rpx;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f0e8;
  border: 3rpx solid #d4c5a9;
  border-radius: 10rpx;
  position: relative;
  transition: all 0.15s;
}

.tile-selector.selected {
  background: #e8f5e9;
  border-color: #2d5016;
  box-shadow: 0 2rpx 8rpx rgba(45, 80, 22, 0.2);
}

.tile-selector:active {
  transform: scale(0.95);
}

.tile-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.tile-badge {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  background: #2d5016;
  color: #fff;
  border-radius: 50%;
  font-weight: bold;
}

/* 操作区 */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}
