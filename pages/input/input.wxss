/* pages/input/input.wxss */

/* 拍照预览 */
.photo-preview {
  width: 100%;
  height: 240rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  border: 2rpx solid #e0d4b8;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

/* 已选区域 */
.selected-area {
  width: 100%;
  margin-bottom: 24rpx;
}

.selected-title {
  font-size: 28rpx;
  color: #2d5016;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-align: center;
}

.tile-empty {
  width: 48rpx;
  height: 56rpx;
  border: 2rpx dashed #ccc;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.5);
}

/* 已选手牌区域：放大尺寸 + 删除按钮 */
.tile-item-large {
  width: 80rpx !important;
  height: 100rpx !important;
  line-height: 100rpx !important;
  font-size: 76rpx !important;
  position: relative;
}

.tile-empty-large {
  width: 80rpx;
  height: 100rpx;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.5);
}

.tile-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: #c0392b;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.25);
  z-index: 2;
}

.tile-delete:active {
  transform: scale(0.85);
  opacity: 0.8;
}

/* 上下文区域 */
.context-area {
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.context-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.context-label {
  font-size: 24rpx;
  color: #666;
}

.context-check {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #2d5016;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #2d5016;
}

.context-check.checked {
  background: #2d5016;
  color: #fff;
}

.context-picker {
  font-size: 28rpx;
  color: #2d5016;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  background: #fafafa;
}

/* 花牌区域 */
.flower-area {
  width: 100%;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.flower-title {
  font-size: 26rpx;
  color: #2d5016;
  font-weight: bold;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #2d5016;
}

.flower-list {
  display: flex;
  flex-wrap: nowrap;
  gap: 4rpx;
  justify-content: space-between;
}

.flower-item {
  width: 72rpx;
  height: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e0d4b8;
  border-radius: 6rpx;
  background: #fafafa;
  transition: all 0.15s;
}

.flower-selected {
  background: rgba(45, 80, 22, 0.12);
  border-color: #2d5016;
  border-width: 2rpx;
}

.flower-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.flower-name {
  font-size: 18rpx;
  color: #555;
  margin-top: 2rpx;
}

/* 牌面选择网格 */
.tiles-grid {
  width: 100%;
  margin-bottom: 24rpx;
}

.suit-group {
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.suit-label {
  font-size: 26rpx;
  color: #2d5016;
  font-weight: bold;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #2d5016;
}

.suit-tiles {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.tile-selector {
  width: 72rpx;
  height: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 8rpx;
  position: relative;
  transition: all 0.15s;
  background: transparent;
}

.tile-selector.selected {
  background: rgba(45, 80, 22, 0.12);
  box-shadow: none;
  transform: none;
}

.tile-selector:active {
  transform: scale(0.92);
}

.tile-name {
  font-size: 72rpx;
  line-height: 1;
}

/* 去掉花色背景，emoji自带颜色 */

.tile-badge {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 24rpx;
  height: 24rpx;
  line-height: 24rpx;
  text-align: center;
  font-size: 16rpx;
  background: #2d5016;
  color: #fff;
  border-radius: 50%;
  font-weight: bold;
}

/* 操作区 */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}
