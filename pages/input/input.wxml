<!-- pages/input/input.wxml -->
<view class="container">
  <!-- 拍照预览 -->
  <view class="photo-preview" wx:if="{{cameraPhoto}}">
    <image class="photo-thumb" src="{{cameraPhoto}}" mode="aspectFit"></image>
  </view>

  <!-- 已选手牌展示区 -->
  <view class="selected-area">
    <view class="selected-title">
      已选手牌 ({{totalCount}}/{{maxTiles}})
    </view>
    <view class="tile-display">
      <block wx:for="{{selectedTiles}}" wx:key="index">
        <view class="tile-item tile-item-large tile-suit-{{item.suit}}">
          {{item.emoji}}
          <view
            class="tile-delete"
            catchtap="onDeleteSelected"
            data-tile-id="{{item.id}}"
          >×</view>
        </view>
      </block>
      <!-- 空位 -->
      <block wx:for="{{maxTiles - totalCount}}" wx:key="*this">
        <view class="tile-empty tile-empty-large"></view>
      </block>
    </view>
  </view>

  <!-- 上下文选项 -->
  <view class="context-area">
    <view class="context-item" bindtap="onToggleSelfDraw">
      <view class="context-label">自摸</view>
      <view class="context-check {{isSelfDraw ? 'checked' : ''}}">
        <text wx:if="{{isSelfDraw}}">✓</text>
      </view>
    </view>

    <view class="context-item" bindtap="onToggleConcealed">
      <view class="context-label">门前清</view>
      <view class="context-check {{isConcealed ? 'checked' : ''}}">
        <text wx:if="{{isConcealed}}">✓</text>
      </view>
    </view>

    <view class="context-item">
      <view class="context-label">圈风</view>
      <picker mode="selector" range="{{prevalentWinds}}" value="{{prevalentWindIndex}}" bindchange="onPrevalentWindChange">
        <view class="context-picker">{{prevalentWinds[prevalentWindIndex]}}</view>
      </picker>
    </view>

    <view class="context-item">
      <view class="context-label">门风</view>
      <picker mode="selector" range="{{seatWinds}}" value="{{seatWindIndex}}" bindchange="onSeatWindChange">
        <view class="context-picker">{{seatWinds[seatWindIndex]}}</view>
      </picker>
    </view>
  </view>

  <!-- 花牌选择区 -->
  <view class="flower-area">
    <view class="flower-title">花</view>
    <view class="flower-list">
      <view
        wx:for="{{flowers}}"
        wx:key="name"
        wx:for-index="idx"
        class="flower-item {{item.selected ? 'flower-selected' : ''}}"
        data-idx="{{idx}}"
        bindtap="onToggleFlower"
      >
        <view class="flower-emoji">{{item.emoji}}</view>
        <view class="flower-name">{{item.name}}</view>
      </view>
    </view>
  </view>

  <!-- 牌面选择区 -->
  <view class="tiles-grid">
    <block wx:for="{{tileGroups}}" wx:key="name">
      <view class="suit-group">
        <view class="suit-label">{{item.name}}</view>
        <view class="suit-tiles">
          <view
            wx:for="{{item.tiles}}"
            wx:key="id"
            wx:for-item="tile"
            class="tile-selector {{tile.colorClass}} {{tile.count > 0 ? 'selected' : ''}}"
            data-tile-id="{{tile.id}}"
            bindtap="onTapTile"
            bindlongpress="onLongPressTile"
          >
            <view class="tile-name">{{tile.emoji}}</view>
            <view class="tile-badge" wx:if="{{tile.count > 0}}">{{tile.count}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 操作按钮 -->
  <view class="action-area">
    <button
      class="btn-primary {{totalCount >= 14 ? '' : 'btn-disabled'}}"
      bindtap="onCalculate"
      disabled="{{totalCount < 14}}"
    >
      计算番数
    </button>
    <button class="btn-secondary" bindtap="onClear">清空重置</button>
  </view>
</view>
